<script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
<script>
    AOS.init({
        duration: 1000,
        once: true,
    });
</script>

<!-- Auto-Swipe Script -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        let carousel = new bootstrap.Carousel(document.getElementById('customerReviewsCarousel'), {
            interval: 4000, // Change slide every 4 seconds
            ride: "carousel"
        });
    });
</script>
