@{
    ViewData["Title"] = "Home";
}

<!-- Navbar Section -->
<header class="navbar-section bg-white shadow-sm">
    <div class="container py-3 d-flex justify-content-between align-items-center">
        <img src="/images/logo.png" alt="Logo" style="height: 50px;" />
        <nav class="nav">
            <a asp-controller="Home" asp-action="Index" class="nav-link text-dark fw-bold">Home</a>
            <a asp-controller="Home" asp-action="About" class="nav-link text-dark">About</a>
            <a asp-controller="Home" asp-action="Tours" class="nav-link text-dark">Tours</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary me-2">Login</a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary">Register</a>
        </nav>
    </div>
</header>

<!-- Hero Section -->
<section id="home" class="container-fluid py-5">
<div class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <!-- Hero Text -->
            <div class="col-md-6 col-12">
                <button class="btn btn-warning mb-3 px-4 py-2">
                    Know Before You Go <i class="fas fa-globe"></i>
                </button>
                <h1 class="fw-bold">
                    Traveling opens the door to creating <span class="highlight text-warning">memories</span>
                </h1>
                <p class="mt-3 text-secondary">
                    Explore the world with ease. Discover breathtaking destinations, plan unforgettable trips, and enjoy seamless experiences.
                </p>
            </div>

            <!-- Hero Media -->
            <div class="col-md-6 col-12">
                <div class="d-flex justify-content-between gap-3">
                    <img src="/images/hero-img01.jpg" alt="Destination 1" class="img-fluid rounded media-item" />
                    <video autoplay muted loop poster="/images/video-placeholder.jpg" class="img-fluid rounded media-item">
                        <source src="/videos/hero-video.mp4" type="video/mp4">
                        Your browser does not support the video tag.
                    </video>
                    <img src="/images/hero-img02.jpg" alt="Destination 2" class="img-fluid rounded media-item" />
                </div>
            </div>
        </div>

        <!-- Search Bar -->
        <div class="search-bar mt-4 p-4 rounded shadow-sm">
            <form class="d-flex gap-3 justify-content-center align-items-center">
                <div class="text-center">
                    <label class="form-label fw-bold text-secondary mb-1">Location</label>
                    <div class="input-group">
                        <span class="input-group-text bg-warning text-white">
                            <i class="fas fa-map-marker-alt"></i>
                        </span>
                        <input type="text" placeholder="Where are you going?" class="form-control form-control-lg" />
                    </div>
                </div>
                <div class="text-center">
                    <label class="form-label fw-bold text-secondary mb-1">Distance</label>
                    <div class="input-group">
                        <span class="input-group-text bg-warning text-white">
                            <i class="fas fa-route"></i>
                        </span>
                        <input type="number" placeholder="Distance (km)" class="form-control form-control-lg" />
                    </div>
                </div>
                <div class="text-center">
                    <label class="form-label fw-bold text-secondary mb-1">Max People</label>
                    <div class="input-group">
                        <span class="input-group-text bg-warning text-white">
                            <i class="fas fa-users"></i>
                        </span>
                        <input type="number" placeholder="0" class="form-control form-control-lg" />
                    </div>
                </div>
                <button type="submit" class="btn btn-warning btn-lg px-5">
                    <i class="fas fa-search"></i> Search
                </button>
            </form>
        </div>
    </div>
</div>

