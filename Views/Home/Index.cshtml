    <!-- Styles -->
    <style>

        .hero-section {
            padding: 60px 0;
            background: #f9f9f9;
        }

        .search-bar {
            background: #fff;
            border-radius: 12px;
        }

            .search-bar .btn {
                background-color: #f39c12;
                border: none;
                color: #fff;
                font-weight: bold;
            }

        h1 span {
            color: #f39c12;
        }

        .media-item {
            height: 220px;
            width: 220px;
            border-radius: 10px;
            object-fit: cover;
            box-shadow: 0px 6px 8px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .media-item:hover {
                transform: scale(1.05);
                box-shadow: 0px 10px 15px rgba(0, 0, 0, 0.2);
            }

        .services-section {
            padding: 60px 0;
            background: #fff;
            text-align: center;
        }

        .service-cards {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-top: 30px;
        }

        .service-card {
            background: #f9f9f9;
            padding: 20px;
            border-radius: 12px;
            width: 250px;
            text-align: center;
            box-shadow: 0px 6px 10px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s;
        }

            .service-card:hover {
                transform: translateY(-5px);
            }

            .service-card .icon {
                font-size: 30px;
                color: #f39c12;
                margin-bottom: 10px;
            }

        .review-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.1);
            padding: 20px;
        }

        .review-img {
            width: 80px;
            height: 80px;
            object-fit: cover;
        }

        .review-stars i {
            font-size: 18px;
        }

    </style>

    <!-- Font Awesome & AOS Library -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css">
    <!-- Bootstrap Icons CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <script>
        AOS.init({
            duration: 1000,
            once: true,
        });
    </script>

    <!-- Auto-Swipe Script -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let carousel = new bootstrap.Carousel(document.getElementById('customerReviewsCarousel'), {
                interval: 4000, // Change slide every 4 seconds
                ride: "carousel"
            });
        });
    </script>
