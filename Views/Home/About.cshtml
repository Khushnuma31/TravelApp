@{
    ViewData["Title"] = "About Us";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <h1>About Us</h1>
        <p>Your perfect travel partner for unforgettable experiences.</p>
    </div>
</section>

<!-- About Company Section -->
<section class="about-company">
    <div class="container">
        <div class="about-content">
            <div class="about-text">
                <h2>Who We Are</h2>
                <p>
                    We are a passionate team dedicated to making your travel dreams come true. With years of experience,
                    we ensure unforgettable journeys to the world's most stunning destinations.
                </p>
                <p>
                    From luxury resorts to adventurous getaways, we tailor every trip to your preferences.
                </p>
            </div>
            <div class="about-image">
                <img src="~/images/about.jpg" alt="About Us">
            </div>
        </div>
    </div>
</section>

<!-- Why Choose Us Section -->
<section class="why-choose-us">
    <div class="container">
        <h2>Why Choose Us?</h2>
        <div class="reasons">
            <div class="reason">
                <i class="fas fa-plane"></i>
                <h3>Best Destinations</h3>
                <p>Explore top travel locations worldwide with ease.</p>
            </div>
            <div class="reason">
                <i class="fas fa-hotel"></i>
                <h3>Luxury Stays</h3>
                <p>Enjoy 5-star accommodations at the best resorts and hotels.</p>
            </div>
            <div class="reason">
                <i class="fas fa-headset"></i>
                <h3>24/7 Support</h3>
                <p>Our support team is always available for your travel needs.</p>
            </div>
        </div>
    </div>
</section>

<!-- Our Services Section -->
<section class="our-services">
    <div class="container">
        <h2>Our Services</h2>
        <div class="services-list">
            <div class="service">
                <i class="fas fa-map-marked-alt"></i>
                <h3>Custom Travel Plans</h3>
                <p>Tailored travel experiences based on your preferences.</p>
            </div>
            <div class="service">
                <i class="fas fa-bus"></i>
                <h3>Transport & Rentals</h3>
                <p>Reliable transport and rental services for a hassle-free journey.</p>
            </div>
            <div class="service">
                <i class="fas fa-utensils"></i>
                <h3>Food & Cuisine</h3>
                <p>Enjoy exquisite local and international dining experiences.</p>
            </div>
        </div>
    </div>
</section>

<!-- Customer Reviews Section -->
<section class="customer-reviews">
    <div class="container">
        <h2>What Our Customers Say</h2>
        <div class="reviews">
            <div class="review">
                <p>"Amazing experience! The team made our vacation perfect. Highly recommend!"</p>
                <h4>- Sarah Thompson</h4>
            </div>
            <div class="review">
                <p>"Best travel agency I've ever used. Everything was perfectly organized!"</p>
                <h4>- Michael Johnson</h4>
            </div>
        </div>
    </div>
</section>

<!-- Meet Our Team Section -->
<section class="our-team">
    <div class="container">
        <h2>Meet Our Team</h2>
        <div class="team-members">
            <div class="member">
                <img src="~/images/team1.jpg" alt="Team Member">
                <h3>John Doe</h3>
                <p>Founder & CEO</p>
            </div>
            <div class="member">
                <img src="~/images/team2.jpg" alt="Team Member">
                <h3>Jane Smith</h3>
                <p>Travel Consultant</p>
            </div>
        </div>
    </div>
</section>

<style>
    /* Hero Section */
    .hero-section {
        background: url('../images/banner.jpg') no-repeat center;
        background-size: cover;
        text-align: center;
        color: white;
        padding: 80px 20px;
    }

        .hero-section h1 {
            font-size: 2.5rem;
            font-weight: bold;
        }

    /* About Section */
    .about-company {
        padding: 60px 20px;
        display: flex;
        align-items: center;
    }

    .about-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .about-text {
        width: 50%;
    }

    .about-image img {
        width: 100%;
        border-radius: 10px;
    }

    /* Why Choose Us */
    .why-choose-us {
        text-align: center;
        padding: 60px 20px;
        background: #f9f9f9;
    }

    .reasons {
        display: flex;
        justify-content: center;
        gap: 20px;
    }

    .reason {
        background: #fff;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        width: 250px;
        text-align: center;
    }

        .reason i {
            font-size: 40px;
            color: #f4a261;
            margin-bottom: 10px;
        }

    /* Services */
    .our-services {
        text-align: center;
        padding: 60px 20px;
    }

    .services-list {
        display: flex;
        justify-content: center;
        gap: 20px;
    }

    .service {
        background: #fff;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        width: 250px;
        text-align: center;
    }

        .service i {
            font-size: 40px;
            color: #ff5733;
            margin-bottom: 10px;
        }

    /* Customer Reviews */
    .customer-reviews {
        text-align: center;
        padding: 60px 20px;
        background: #f9f9f9;
    }

    .reviews {
        display: flex;
        justify-content: center;
        gap: 20px;
    }

    .review {
        background: #fff;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        width: 300px;
        text-align: center;
    }

    /* Team Section */
    .our-team {
        text-align: center;
        padding: 60px 20px;
    }

    .team-members {
        display: flex;
        justify-content: center;
        gap: 20px;
    }

    .member {
        text-align: center;
    }

        .member img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
        }

</style>