@{
    ViewData["Title"] = "Book Your Trip";
    var place = ViewData["Place"] as string ?? "Snowy Mountains, Thailand";
    var img = ViewData["Image"] as string ?? "~/images/tour-img01.jpg";
    var price = ViewData["Price"] as string ?? "99";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Your Trip - @place</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/styles.css">

    <style>
        body {
            font-family: Arial, sans-serif;
        }

        .details-container {
            display: flex;
            gap: 30px;
            padding: 40px;
        }

        .left-section {
            flex: 2;
        }

        .right-section {
            flex: 1;
            background: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0px 0px 10px rgba(0,0,0,0.1);
        }

        .price-tag {
            font-size: 24px;
            font-weight: bold;
            color: #ff9800;
        }

        .star-rating {
            color: #ff9800;
        }

        .book-now-btn {
            background: #ff9800;
            border: none;
            color: white;
            padding: 12px;
            width: 100%;
            font-size: 18px;
            border-radius: 5px;
        }

        .review-section {
            padding: 40px;
        }

        .review-box {
            border: 1px solid #ddd;
            padding: 15px;
            border-radius: 5px;
            background: #fff;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-light bg-light">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Travel<span class="text-warning">Buddy</span></a>
        </div>
    </nav>

    <!-- Main Booking Section -->
    <div class="container details-container">
        <!-- Left Side (Place Details) -->
        <div class="left-section">
            <h2 class="fw-bold">@place</h2>
            <p class="text-muted">
                <span class="star-rating">⭐ 5.0</span> (1) &nbsp; | &nbsp;
                <span>📍 Bangkok, Thailand</span> &nbsp; | &nbsp;
                <span>👥 8 people</span>
            </p>

            <img src="@Url.Content(img)" class="img-fluid rounded shadow" alt="@place">

            <h4 class="mt-3 fw-bold">Description</h4>
            <p>This is the description.</p>
        </div>

        <!-- Right Side (Booking Form) -->
        <div class="right-section">
            <h4 class="price-tag">$@price <small>/ per person</small></h4>

            <form>
                <div class="mb-3">
                    <label class="form-label fw-bold">Full Name</label>
                    <input type="text" class="form-control" placeholder="Enter your name" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Phone</label>
                    <input type="text" class="form-control" placeholder="Enter your phone number" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Travel Date</label>
                    <input type="date" class="form-control" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Guests</label>
                    <select class="form-control">
                        <option>1 Guest</option>
                        <option>2 Guests</option>
                        <option>3 Guests</option>
                        <option>4 Guests</option>
                    </select>
                </div>

                <div class="mb-3">
                    <p><strong>Service charge:</strong> $10</p>
                    <h5 class="fw-bold">Total: $@(Convert.ToInt32(price) + 10)</h5>
                </div>

                <button type="submit" class="book-now-btn">Book Now</button>
            </form>
        </div>
    </div>

    <!-- Reviews Section -->
    <div class="container review-section">
        <h3 class="fw-bold">Reviews (1 Review)</h3>
        <div class="review-box">
            <p class="star-rating">⭐⭐⭐⭐⭐ <small>(5.0)</small></p>
            <p><strong>User</strong> - January 14, 2023</p>
            <p>This is an awesome tour.</p>
        </div>
    </div>

    <!-- Footer -->
    <footer class="container-fluid bg-light py-3 text-center">
        <p class="text-muted">Copyright &copy; 2023 Travel Buddy. All rights reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
