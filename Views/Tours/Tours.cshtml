@{
    ViewData["Title"] = "All Tours";
}

<!-- Fullscreen Hero Banner -->
<section class="hero w-100" style="background: url('/images/banner.jpg') center/cover no-repeat; height: 300px;">
    <div class="container-fluid h-100 d-flex align-items-center justify-content-center">
        <h1 class="text-white fw-bold display-4 text-center">All Tours</h1>
    </div>
</section>

<!-- Search & Tours Section -->
<section class="container-fluid px-5 my-5">
    <!-- Search Filters -->
    <div class="row mb-4 gx-3 gy-2 justify-content-center">
        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
            <input type="text" class="form-control" placeholder="Location" />
        </div>
        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
            <input type="text" class="form-control" placeholder="Distance (km)" />
        </div>
        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
            <input type="number" class="form-control" placeholder="Max People" />
        </div>
        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
            <button class="btn btn-warning w-100">🔍 Search</button>
        </div>
    </div>

    <!-- Tour Cards -->
    <div class="row g-4">
        @foreach (var tour in new[] {
        new { Title = "Westminister Bridge", Location = "London", Rating = 4.8, Reviews = 2, Image = "tour-img01.jpg" },
        new { Title = "Bali, Indonesia", Location = "Indonesia", Rating = 4.6, Reviews = 1, Image = "tour-img02.jpg" },
        new { Title = "Snowy Mountains", Location = "Thailand", Rating = 4.6, Reviews = 1, Image = "tour-img03.jpg" },
        new { Title = "Beautiful Sunrise", Location = "Thailand", Rating = 4.6, Reviews = 1, Image = "tour-img04.jpg" },
        new { Title = "Paris Getaway", Location = "France", Rating = 4.9, Reviews = 3, Image = "tour-img05.jpg" },
        new { Title = "Santorini Escape", Location = "Greece", Rating = 4.7, Reviews = 2, Image = "tour-img06.jpg" },
        new { Title = "Safari Adventure", Location = "Kenya", Rating = 4.8, Reviews = 4, Image = "tour-img07.jpg" },
        new { Title = "Great Wall Trek", Location = "China", Rating = 4.5, Reviews = 3, Image = "tour-img01.jpg" },
        new { Title = "Tokyo Highlights", Location = "Japan", Rating = 4.9, Reviews = 5, Image = "tour-img03.jpg" },
        new { Title = "Grand Canyon", Location = "USA", Rating = 4.8, Reviews = 6, Image = "tour-img02.jpg" },
        new { Title = "Northern Lights", Location = "Iceland", Rating = 4.9, Reviews = 7, Image = "tour-img04.jpg" },
        new { Title = "Petra Discovery", Location = "Jordan", Rating = 4.7, Reviews = 2, Image = "tour-img05.jpg" },
        new { Title = "Sahara Dunes", Location = "Morocco", Rating = 4.6, Reviews = 3, Image = "tour-img06.jpg" },
        new { Title = "Machu Picchu", Location = "Peru", Rating = 4.8, Reviews = 4, Image = "tour-img07.jpg" },
        new { Title = "Sydney Tour", Location = "Australia", Rating = 4.5, Reviews = 2, Image = "tour-img01.jpg" },
        new { Title = "Dubai Luxury", Location = "UAE", Rating = 4.9, Reviews = 5, Image = "tour-img02.jpg" }
        })
        {
            <div class="col-xl-3 col-lg-4 col-md-6">
                <div class="card h-100 border-0 shadow-sm">
                    <img src="~/images/@tour.Image" class="card-img-top img-fluid" alt="@tour.Title">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between mb-2">
                            <small class="text-muted">@tour.Location</small>
                            <span class="badge bg-warning text-dark">Featured</span>
                        </div>
                        <h5 class="card-title">@tour.Title</h5>
                        <div class="text-muted small mb-3">
                            ⭐ @tour.Rating (@tour.Reviews)
                        </div>
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-primary">$99 <small class="text-muted">/person</small></span>
                            <a href="/Booking/Book?destination=@tour.Title" class="btn btn-sm btn-warning">Book Now</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
