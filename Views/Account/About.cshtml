@{
    ViewData["Title"] = "About Us";
}

<!-- About Us Section -->
<div class="container my-5">
    <div class="row align-items-center shadow-lg p-5 rounded bg-white">
        <!-- Left Side: Image -->
        <div class="col-md-6">
            <img src="~/images/about-us.jpg" alt="About Us" class="img-fluid rounded">
        </div>

        <!-- Right Side: Text Content -->
        <div class="col-md-6">
            <h2 class="fw-bold text-warning">About Us</h2>
            <p class="text-secondary">
                Welcome to <strong>TravelApp</strong>, your go-to platform for unforgettable travel experiences.
                We are passionate about helping you explore the world, find hidden gems, and make memories that last a lifetime.
            </p>
            <p class="text-secondary">
                Whether you're looking for breathtaking landscapes, cultural adventures, or relaxing getaways, we provide curated tours and personalized recommendations just for you.
            </p>
            <button class="btn btn-warning mt-3">Learn More</button>
        </div>
    </div>
</div>

<!-- Our Mission Section -->
<section class="container my-5">
    <div class="text-center">
        <h2 class="fw-bold">Our Mission</h2>
        <p class="text-secondary">We aim to make travel easy, accessible, and enjoyable for everyone.</p>
    </div>
    <div class="row text-center mt-4">
        <div class="col-md-4">
            <i class="fas fa-globe fa-3x text-warning"></i>
            <h5 class="mt-3">Explore the World</h5>
            <p class="text-secondary">Discover amazing destinations and unique experiences.</p>
        </div>
        <div class="col-md-4">
            <i class="fas fa-handshake fa-3x text-warning"></i>
            <h5 class="mt-3">Best Services</h5>
            <p class="text-secondary">We ensure top-quality service and customer satisfaction.</p>
        </div>
        <div class="col-md-4">
            <i class="fas fa-users fa-3x text-warning"></i>
            <h5 class="mt-3">Community</h5>
            <p class="text-secondary">Join a community of travel enthusiasts and share your experiences.</p>
        </div>
    </div>
</section>

<!-- Styles (Same as Other Pages) -->
<style>
    .shadow-lg {
        box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
    }

    .text-warning {
        color: #f39c12;
    }

    .btn-warning {
        background-color: #f39c12;
        border: none;
        color: white;
        font-weight: bold;
    }

    h2 {
        font-size: 2.5rem;
    }

    p {
        font-size: 1.1rem;
    }

    img {
        border-radius: 10px;
    }
</style>

<!-- Font Awesome (for Icons) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
